{
  "$defs": {
    "ArtifactReference": {
      "properties": {
        "created_by_attempt": {
          "title": "Created By Attempt",
          "type": "integer"
        },
        "created_by_stage": {
          "title": "Created By Stage",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "logical_name": {
          "title": "Logical Name",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "row_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Row Count"
        },
        "schema_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Name"
        },
        "schema_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "relative_path",
        "media_type",
        "sha256",
        "size_bytes",
        "created_by_stage",
        "created_by_attempt"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "ContractProvenance": {
      "properties": {
        "config_revision": {
          "default": 1,
          "title": "Config Revision",
          "type": "integer"
        },
        "dependency_contract_hashes": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Dependency Contract Hashes",
          "type": "object"
        },
        "extra": {
          "additionalProperties": true,
          "title": "Extra",
          "type": "object"
        },
        "fingerprint_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fingerprint Hash"
        }
      },
      "title": "ContractProvenance",
      "type": "object"
    },
    "EvidenceMetricRecordV1": {
      "properties": {
        "backend": {
          "title": "Backend",
          "type": "string"
        },
        "backend_version": {
          "title": "Backend Version",
          "type": "string"
        },
        "calculation_status": {
          "title": "Calculation Status",
          "type": "string"
        },
        "is_heuristic": {
          "title": "Is Heuristic",
          "type": "boolean"
        },
        "missing_value_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Missing Value Reason"
        },
        "value": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "value",
        "backend",
        "backend_version",
        "calculation_status",
        "is_heuristic"
      ],
      "title": "EvidenceMetricRecordV1",
      "type": "object"
    },
    "GeneSequenceEvidenceRecordV1": {
      "properties": {
        "gene": {
          "title": "Gene",
          "type": "string"
        },
        "transcripts": {
          "items": {
            "$ref": "#/$defs/TranscriptSequenceEvidenceRecordV1"
          },
          "title": "Transcripts",
          "type": "array"
        }
      },
      "required": [
        "gene",
        "transcripts"
      ],
      "title": "GeneSequenceEvidenceRecordV1",
      "type": "object"
    },
    "SequenceAnalysisPayload": {
      "properties": {
        "sequence_hits": {
          "additionalProperties": {
            "$ref": "#/$defs/GeneSequenceEvidenceRecordV1"
          },
          "title": "Sequence Hits",
          "type": "object"
        },
        "total_sites": {
          "title": "Total Sites",
          "type": "integer"
        },
        "transcript_count": {
          "title": "Transcript Count",
          "type": "integer"
        }
      },
      "required": [
        "sequence_hits",
        "total_sites",
        "transcript_count"
      ],
      "title": "SequenceAnalysisPayload",
      "type": "object"
    },
    "SequenceBindingSiteRecordV1": {
      "properties": {
        "accessibility_evidence": {
          "$ref": "#/$defs/EvidenceMetricRecordV1"
        },
        "central_pairing": {
          "title": "Central Pairing",
          "type": "boolean"
        },
        "cleavage_compatible": {
          "title": "Cleavage Compatible",
          "type": "boolean"
        },
        "complementarity_score": {
          "title": "Complementarity Score",
          "type": "number"
        },
        "duplex_energy_evidence": {
          "$ref": "#/$defs/EvidenceMetricRecordV1"
        },
        "full_length_complementarity": {
          "title": "Full Length Complementarity",
          "type": "boolean"
        },
        "gene": {
          "title": "Gene",
          "type": "string"
        },
        "genomic_coordinates": {
          "anyOf": [
            {
              "items": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "title": "Genomic Coordinates"
        },
        "gu_wobble_count": {
          "title": "Gu Wobble Count",
          "type": "integer"
        },
        "guide_coordinates": {
          "items": {
            "type": "integer"
          },
          "title": "Guide Coordinates",
          "type": "array"
        },
        "match_type": {
          "title": "Match Type",
          "type": "string"
        },
        "mismatch_count": {
          "title": "Mismatch Count",
          "type": "integer"
        },
        "mismatch_positions": {
          "items": {
            "type": "integer"
          },
          "title": "Mismatch Positions",
          "type": "array"
        },
        "opening_energy_evidence": {
          "$ref": "#/$defs/EvidenceMetricRecordV1"
        },
        "provenance": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Provenance",
          "type": "object"
        },
        "region": {
          "title": "Region",
          "type": "string"
        },
        "seed_class": {
          "title": "Seed Class",
          "type": "string"
        },
        "site_sequence": {
          "title": "Site Sequence",
          "type": "string"
        },
        "strand_source": {
          "title": "Strand Source",
          "type": "string"
        },
        "supplementary_pairing": {
          "title": "Supplementary Pairing",
          "type": "boolean"
        },
        "target_window_coordinates": {
          "items": {
            "type": "integer"
          },
          "title": "Target Window Coordinates",
          "type": "array"
        },
        "transcript": {
          "title": "Transcript",
          "type": "string"
        },
        "transcript_end": {
          "title": "Transcript End",
          "type": "integer"
        },
        "transcript_start": {
          "title": "Transcript Start",
          "type": "integer"
        }
      },
      "required": [
        "gene",
        "transcript",
        "strand_source",
        "match_type",
        "seed_class",
        "mismatch_count",
        "mismatch_positions",
        "transcript_start",
        "transcript_end",
        "region",
        "site_sequence",
        "guide_coordinates",
        "target_window_coordinates",
        "genomic_coordinates",
        "complementarity_score",
        "full_length_complementarity",
        "central_pairing",
        "cleavage_compatible",
        "supplementary_pairing",
        "gu_wobble_count",
        "accessibility_evidence",
        "opening_energy_evidence",
        "duplex_energy_evidence"
      ],
      "title": "SequenceBindingSiteRecordV1",
      "type": "object"
    },
    "TranscriptSequenceEvidenceRecordV1": {
      "properties": {
        "binding_sites": {
          "items": {
            "$ref": "#/$defs/SequenceBindingSiteRecordV1"
          },
          "title": "Binding Sites",
          "type": "array"
        },
        "gene": {
          "title": "Gene",
          "type": "string"
        },
        "transcript": {
          "title": "Transcript",
          "type": "string"
        }
      },
      "required": [
        "gene",
        "transcript",
        "binding_sites"
      ],
      "title": "TranscriptSequenceEvidenceRecordV1",
      "type": "object"
    }
  },
  "properties": {
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "attempt_number": {
      "title": "Attempt Number",
      "type": "integer"
    },
    "contract_name": {
      "title": "Contract Name",
      "type": "string"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/SequenceAnalysisPayload"
    },
    "provenance": {
      "$ref": "#/$defs/ContractProvenance"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "software_version": {
      "default": "0.1.0",
      "title": "Software Version",
      "type": "string"
    },
    "stage_name": {
      "title": "Stage Name",
      "type": "string"
    },
    "stage_version": {
      "title": "Stage Version",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "contract_name",
    "stage_name",
    "stage_version",
    "run_id",
    "attempt_number",
    "payload"
  ],
  "title": "SequenceAnalysisResultV1",
  "type": "object"
}
