{
  "$defs": {
    "ArtifactReference": {
      "properties": {
        "created_by_attempt": {
          "title": "Created By Attempt",
          "type": "integer"
        },
        "created_by_stage": {
          "title": "Created By Stage",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "logical_name": {
          "title": "Logical Name",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "row_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Row Count"
        },
        "schema_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Name"
        },
        "schema_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "relative_path",
        "media_type",
        "sha256",
        "size_bytes",
        "created_by_stage",
        "created_by_attempt"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "ContractProvenance": {
      "properties": {
        "config_revision": {
          "default": 1,
          "title": "Config Revision",
          "type": "integer"
        },
        "dependency_contract_hashes": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Dependency Contract Hashes",
          "type": "object"
        },
        "extra": {
          "additionalProperties": true,
          "title": "Extra",
          "type": "object"
        },
        "fingerprint_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fingerprint Hash"
        }
      },
      "title": "ContractProvenance",
      "type": "object"
    },
    "IsoformAnalysisPayload": {
      "properties": {
        "gene_count": {
          "title": "Gene Count",
          "type": "integer"
        },
        "isoform_results": {
          "additionalProperties": {
            "$ref": "#/$defs/IsoformRecordV1"
          },
          "title": "Isoform Results",
          "type": "object"
        }
      },
      "required": [
        "isoform_results",
        "gene_count"
      ],
      "title": "IsoformAnalysisPayload",
      "type": "object"
    },
    "IsoformRecordV1": {
      "properties": {
        "all_transcripts": {
          "items": {
            "type": "string"
          },
          "title": "All Transcripts",
          "type": "array"
        },
        "eligible_transcripts": {
          "items": {
            "type": "string"
          },
          "title": "Eligible Transcripts",
          "type": "array"
        },
        "equal_transcript_prior": {
          "title": "Equal Transcript Prior",
          "type": "number"
        },
        "excluded_transcripts": {
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Excluded Transcripts",
          "type": "array"
        },
        "gene": {
          "title": "Gene",
          "type": "string"
        },
        "inferred_fraction_max": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Inferred Fraction Max"
        },
        "inferred_fraction_min": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "title": "Inferred Fraction Min"
        },
        "target_site_transcript_count": {
          "title": "Target Site Transcript Count",
          "type": "integer"
        },
        "total_transcript_count": {
          "title": "Total Transcript Count",
          "type": "integer"
        },
        "transcripts_with_site": {
          "items": {
            "type": "string"
          },
          "title": "Transcripts With Site",
          "type": "array"
        },
        "transcripts_without_site": {
          "items": {
            "type": "string"
          },
          "title": "Transcripts Without Site",
          "type": "array"
        },
        "warning": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Warning"
        }
      },
      "required": [
        "gene",
        "all_transcripts",
        "eligible_transcripts",
        "excluded_transcripts",
        "transcripts_with_site",
        "transcripts_without_site",
        "total_transcript_count",
        "target_site_transcript_count",
        "equal_transcript_prior",
        "inferred_fraction_min",
        "inferred_fraction_max",
        "warning"
      ],
      "title": "IsoformRecordV1",
      "type": "object"
    }
  },
  "properties": {
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "attempt_number": {
      "title": "Attempt Number",
      "type": "integer"
    },
    "contract_name": {
      "title": "Contract Name",
      "type": "string"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/IsoformAnalysisPayload"
    },
    "provenance": {
      "$ref": "#/$defs/ContractProvenance"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "software_version": {
      "default": "0.1.0",
      "title": "Software Version",
      "type": "string"
    },
    "stage_name": {
      "title": "Stage Name",
      "type": "string"
    },
    "stage_version": {
      "title": "Stage Version",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "contract_name",
    "stage_name",
    "stage_version",
    "run_id",
    "attempt_number",
    "payload"
  ],
  "title": "IsoformAnalysisResultV1",
  "type": "object"
}
