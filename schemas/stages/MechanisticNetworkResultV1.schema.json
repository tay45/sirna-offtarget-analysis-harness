{
  "$defs": {
    "ArtifactReference": {
      "properties": {
        "created_by_attempt": {
          "title": "Created By Attempt",
          "type": "integer"
        },
        "created_by_stage": {
          "title": "Created By Stage",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Description",
          "type": "string"
        },
        "logical_name": {
          "title": "Logical Name",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "relative_path": {
          "title": "Relative Path",
          "type": "string"
        },
        "required": {
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "row_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Row Count"
        },
        "schema_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Name"
        },
        "schema_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Schema Version"
        },
        "sha256": {
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "title": "Size Bytes",
          "type": "integer"
        }
      },
      "required": [
        "logical_name",
        "relative_path",
        "media_type",
        "sha256",
        "size_bytes",
        "created_by_stage",
        "created_by_attempt"
      ],
      "title": "ArtifactReference",
      "type": "object"
    },
    "ContractProvenance": {
      "properties": {
        "config_revision": {
          "default": 1,
          "title": "Config Revision",
          "type": "integer"
        },
        "dependency_contract_hashes": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Dependency Contract Hashes",
          "type": "object"
        },
        "extra": {
          "additionalProperties": true,
          "title": "Extra",
          "type": "object"
        },
        "fingerprint_hash": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fingerprint Hash"
        }
      },
      "title": "ContractProvenance",
      "type": "object"
    },
    "MechanisticEdgeRecordV1": {
      "properties": {
        "confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "evidence": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence"
        },
        "sign": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sign"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "target": {
          "title": "Target",
          "type": "string"
        }
      },
      "required": [
        "source",
        "target"
      ],
      "title": "MechanisticEdgeRecordV1",
      "type": "object"
    },
    "MechanisticNetworkPayload": {
      "properties": {
        "edges": {
          "items": {
            "$ref": "#/$defs/MechanisticEdgeRecordV1"
          },
          "title": "Edges",
          "type": "array"
        },
        "paths": {
          "items": {
            "$ref": "#/$defs/MechanisticPathRecordV1"
          },
          "title": "Paths",
          "type": "array"
        },
        "pathway_results": {
          "additionalProperties": {
            "$ref": "#/$defs/PathwayEnrichmentRecordV1"
          },
          "title": "Pathway Results",
          "type": "object"
        },
        "supported_relation_count": {
          "title": "Supported Relation Count",
          "type": "integer"
        }
      },
      "required": [
        "pathway_results",
        "supported_relation_count"
      ],
      "title": "MechanisticNetworkPayload",
      "type": "object"
    },
    "MechanisticPathRecordV1": {
      "properties": {
        "gene": {
          "title": "Gene",
          "type": "string"
        },
        "path_confidence": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Confidence"
        },
        "path_direction": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path Direction"
        },
        "path_nodes": {
          "items": {
            "type": "string"
          },
          "title": "Path Nodes",
          "type": "array"
        },
        "signed": {
          "default": false,
          "title": "Signed",
          "type": "boolean"
        }
      },
      "required": [
        "gene",
        "path_nodes"
      ],
      "title": "MechanisticPathRecordV1",
      "type": "object"
    },
    "PathwayEnrichmentRecordV1": {
      "properties": {
        "composed_path_sign": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Composed Path Sign"
        },
        "conflicting_paths": {
          "default": false,
          "title": "Conflicting Paths",
          "type": "boolean"
        },
        "contradictory_path_count": {
          "default": 0,
          "title": "Contradictory Path Count",
          "type": "integer"
        },
        "direction_consistency": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "title": "Direction Consistency"
        },
        "evidence_limitations": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Limitations",
          "type": "array"
        },
        "expected_candidate_direction": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Expected Candidate Direction"
        },
        "gene": {
          "title": "Gene",
          "type": "string"
        },
        "paths": {
          "items": {
            "type": "string"
          },
          "title": "Paths",
          "type": "array"
        },
        "pathway_coherence": {
          "title": "Pathway Coherence",
          "type": "number"
        },
        "provider_sources": {
          "items": {
            "type": "string"
          },
          "title": "Provider Sources",
          "type": "array"
        },
        "regulon_evidence": {
          "title": "Regulon Evidence",
          "type": "number"
        },
        "shortest_signed_path": {
          "items": {
            "type": "string"
          },
          "title": "Shortest Signed Path",
          "type": "array"
        },
        "shortest_unsigned_supported_path": {
          "items": {
            "type": "string"
          },
          "title": "Shortest Unsigned Supported Path",
          "type": "array"
        },
        "stress_signature_evidence": {
          "title": "Stress Signature Evidence",
          "type": "number"
        },
        "supporting_path_count": {
          "default": 0,
          "title": "Supporting Path Count",
          "type": "integer"
        },
        "target_pathway_distance": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Target Pathway Distance"
        }
      },
      "required": [
        "gene",
        "target_pathway_distance",
        "direction_consistency",
        "pathway_coherence",
        "regulon_evidence",
        "stress_signature_evidence"
      ],
      "title": "PathwayEnrichmentRecordV1",
      "type": "object"
    }
  },
  "properties": {
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "title": "Artifacts",
      "type": "array"
    },
    "attempt_number": {
      "title": "Attempt Number",
      "type": "integer"
    },
    "contract_name": {
      "title": "Contract Name",
      "type": "string"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "payload": {
      "$ref": "#/$defs/MechanisticNetworkPayload"
    },
    "provenance": {
      "$ref": "#/$defs/ContractProvenance"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "1",
      "title": "Schema Version",
      "type": "string"
    },
    "software_version": {
      "default": "0.1.0",
      "title": "Software Version",
      "type": "string"
    },
    "stage_name": {
      "title": "Stage Name",
      "type": "string"
    },
    "stage_version": {
      "title": "Stage Version",
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "title": "Warnings",
      "type": "array"
    }
  },
  "required": [
    "contract_name",
    "stage_name",
    "stage_version",
    "run_id",
    "attempt_number",
    "payload"
  ],
  "title": "MechanisticNetworkResultV1",
  "type": "object"
}
